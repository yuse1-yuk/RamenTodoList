:root {
  --bg: radial-gradient(circle at 20% 20%, #fef3d7, #ffd2a0 40%, #ffb677 70%, #ff9d6c);
  --panel: rgba(255, 255, 255, 0.8);
  --text: #2f1d14;
  --accent: #c72626;
}

* { box-sizing: border-box; }

body {
  margin: 0;
  min-height: 100vh;
  font-family: 'Noto Sans JP', 'Inter', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
  background: var(--bg);
  color: var(--text);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32px 20px 48px;
}

@media (prefers-reduced-motion: reduce) {
  * {
    animation-duration: 0.001ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.001ms !important;
  }
}

.page {
  width: min(960px, 100%);
  display: grid;
  gap: 20px;
}

.headline {
  text-align: center;
  font-weight: 700;
  font-size: clamp(24px, 4vw, 32px);
  letter-spacing: 0.04em;
  color: var(--accent);
}

.panel {
  background: var(--panel);
  border-radius: 18px;
  padding: 18px 16px;
  backdrop-filter: blur(6px);
  box-shadow: 0 16px 30px rgba(0, 0, 0, 0.08);
}

.form-row {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

input[type='text'] {
  flex: 1 1 220px;
  padding: 12px 14px;
  border-radius: 12px;
  border: 1px solid #e0c9b3;
  font-size: 15px;
  outline: none;
  background: #fffaf4;
}

button {
  cursor: pointer;
  border: none;
  padding: 12px 18px;
  border-radius: 12px;
  background: linear-gradient(135deg, #ff8d4d, #ff5f4c);
  color: white;
  font-weight: 700;
  letter-spacing: 0.02em;
  box-shadow: 0 8px 16px rgba(255, 95, 76, 0.35);
  transition: transform 0.15s ease, box-shadow 0.2s ease;
}

button:hover {
  transform: translateY(-1px) scale(1.01);
  box-shadow: 0 10px 18px rgba(255, 95, 76, 0.35);
}

button:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

.bowl-wrapper {
  position: relative;
  margin: 0 auto;
  width: min(520px, 90vw);
  aspect-ratio: 1 / 1;
  overflow: visible;
}

.bowl {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
  user-select: none;
  pointer-events: none;
  filter: drop-shadow(0 18px 24px rgba(0, 0, 0, 0.15));
}

.topping {
  position: absolute;
  width: clamp(110px, 32vw, 180px);
  transform-origin: center;
  transition: opacity 240ms ease, transform 240ms ease;
  display: grid;
  place-items: center;
  cursor: grab;
  touch-action: none;
  z-index: 1;
}

.topping img {
  width: 100%;
  height: auto;
  object-fit: contain;
  filter: drop-shadow(0 6px 8px rgba(0, 0, 0, 0.2));
}

.topping .label {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
  text-align: center;
  color: white;
  font-weight: 800;
  font-size: clamp(13px, 3vw, 18px);
  padding: 6px;
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.6);
  pointer-events: none;
}

.topping.eating {
  opacity: 0;
  transform: scale(0.85) translateY(8px);
}

.topping.dragging {
  cursor: grabbing;
  z-index: 5;
}

.list {
  display: grid;
  gap: 8px;
  margin-top: 8px;
}

.list-item {
  background: rgba(255, 255, 255, 0.72);
  border-radius: 10px;
  padding: 10px 12px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
  color: #2f1d14;
  border: 1px solid #f0d9c4;
}

.list-item .name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.list-item .mini {
  font-size: 12px;
  color: #a26a3a;
}

@media (max-width: 640px) {
  body { padding: 20px 12px 32px; }
  .panel { padding: 14px 12px; }
  .bowl-wrapper { width: min(420px, 100vw); }
}
